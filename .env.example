# Intuit / QuickBooks Online
# Create your app at https://developer.intuit.com → Keys & OAuth tab
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REALM_ID=                        # Your company ID (visible in the QBO URL)
QBO_REDIRECT_URI=http://localhost:8080/callback
QBO_ENVIRONMENT=production           # "production" or "sandbox"
QBO_TOKEN_FILE=~/.qbo_token.json     # Writable path for OAuth token storage

# Anthropic
ANTHROPIC_API_KEY=

# Categorization
# Transactions with LLM confidence >= this threshold are auto-applied.
# Anything below is held for human review. 0.90 is conservative (recommended).
CONFIDENCE_THRESHOLD=0.90
